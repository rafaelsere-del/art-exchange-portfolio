rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users + artworks subcollection
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || isAdmin());

      match /artworks/{artworkId} {
        allow read: if isAuth();
        allow write: if isAuth() && (request.auth.uid == userId || isAdmin());
      }
    }

    // Likes
    match /likes/{likeId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.from == request.auth.uid;
      allow delete: if isAuth() && resource.data.from == request.auth.uid;
    }

    // Matches + messages subcollection
    match /matches/{matchId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
      }
    }

    // Applications — anyone can create (apply), admins manage
    match /applications/{appId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // Invitations — admin only
    match /invitations/{invId} {
      allow read, write: if isAdmin();
    }

    // Settings — authenticated read, admin write
    match /settings/{settingId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
